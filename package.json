{
  "name": "ai-workflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r run build",
    "build:components": "pnpm --filter @ai-workflow/components build",
    "docs": "pnpm --filter @ai-workflow/docs dev",
    "docs:build": "pnpm --filter @ai-workflow/docs build",
    "docs:preview": "pnpm --filter @ai-workflow/docs preview",
    "release": "tsx scripts/release.ts",
    "changelog": "tsx scripts/release.ts --changelog"
  },
  "devDependencies": {
    "tsx": "^4.7.0"
  }
}
