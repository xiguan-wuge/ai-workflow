{
  "bypassPermissions": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "mcpServers": {
    "openspec": {
      "command": "npx",
      "args": ["-y", "@fission-ai/openspec-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "disallowedTools": [ "Bash(rm *)", "Read(~/Documents/**)" ],
    "autoApprove": true,
    "allow": [
      "Bash:openspec:*",
      "Bash:npm:*",
      "Bash:git:*"
    ],
    "deny": [
      "Bash:rm -rf *",
      "Bash:sudo *",
      "Bash:curl * | bash"
    ]
  }
}
